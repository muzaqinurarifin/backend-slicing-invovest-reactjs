generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Event {
  id          Int      @id @default(autoincrement())
  name        String
  categoryId  String   @map("category_id")
  location    String
  dateEvent   DateTime @map("date_event")
  description String
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("events")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String
  CreatedAt DateTime @default(now()) @map("created_at")

  @@map("categories")
}

model Speaker {
  id        Int      @id @default(autoincrement())
  name      String
  role      String
  image     String
  CreatedAt DateTime @default(now()) @map("created_at")

  @@map("speakers")
}

model Users {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}
